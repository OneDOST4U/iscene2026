rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isNonAdminOwner(uid) {
      return signedIn()
        && request.auth.uid == uid
        && !(request.auth.token.admin == true);
    }

    // Article authors (sector Articles) get a doc here when admin saves their registration — see AdminDashboard.
    function canManageArticleCategories() {
      return isAdmin()
        || exists(/databases/$(database)/documents/articleCategoryEditors/$(request.auth.uid));
    }

    // True when the signed-in user is listed on the room as a presenter (presenterUids).
    function roomPresentersIncludeAuthUid(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId))
        && 'presenterUids' in get(/databases/$(database)/documents/rooms/$(roomId)).data
        && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.presenterUids;
    }

    // ─────────────────────────────────────────────────────────────
    // ADMINS  /admins/{uid}
    // UIDs listed here are treated as admins (alternative to custom claims).
    // Create admins/{your-uid} in Firebase Console to grant admin access.
    // Only existing admins can add/remove others.
    // ─────────────────────────────────────────────────────────────
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // USER PROFILES  /users/{uid}
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // EVENT REGISTRATIONS  /registrations/{docId}
    // Participants may update their own doc (e.g. travelDetails, accommodationDetails).
    // Client must use the real Firestore document id (not an embedded `id` field from data).
    // ─────────────────────────────────────────────────────────────
    match /registrations/{docId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      // Any signed-in user can read registrations.
      // Food booth operators need to look up participant eligibility;
      // presenters and facilitators need to see attendee info for their sessions.
      allow read:   if signedIn();
      allow update: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // ROOMS  /rooms/{docId}
    // Admin creates/deletes; any signed-in user reads.
    // Presenters can update rooms where their uid is in presenterUids.
    // ─────────────────────────────────────────────────────────────
    match /rooms/{docId} {
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (signedIn()
          && 'presenterUids' in resource.data
          && request.auth.uid in resource.data.presenterUids);
      allow read: if signedIn();
    }

    // ─────────────────────────────────────────────────────────────
    // VENUES (Rooms)  /venues/{docId}
    // Admin creates/updates/deletes; any signed-in user reads.
    // Rooms = venue names (Main Hall, Room A, etc.) used in admin UI
    // and in the Conduct Venue dropdown when creating breakout sessions.
    // ─────────────────────────────────────────────────────────────
    match /venues/{docId} {
      allow create, update, delete: if isAdmin();
      allow read: if signedIn();
    }

    // ─────────────────────────────────────────────────────────────
    // MEALS  /meals/{docId}
    // Admin creates/deletes; any signed-in user reads.
    // ─────────────────────────────────────────────────────────────
    match /meals/{docId} {
      allow create, update, delete: if isAdmin();
      allow read: if signedIn();
    }

    // ─────────────────────────────────────────────────────────────
    // RESERVATIONS  /reservations/{docId}
    // Participants manage their own reservations.
    // Any signed-in event staff can read reservations so facilitators
    // can verify room access and view participant schedules.
    // ─────────────────────────────────────────────────────────────
    match /reservations/{docId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read:   if signedIn();
      allow update: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────
    // REVIEWS  /reviews/{docId}
    // Participants create/update their own (uid must stay the same).
    // Admin reads all. Presenters read reviews for rooms where they appear in presenterUids.
    // ─────────────────────────────────────────────────────────────
    match /reviews/{docId} {
      // part4 = required comments; part3.description is optional (omit field if empty — Firestore forbids undefined).
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['roomId', 'uid', 'part4'])
        && request.resource.data.part4 is string
        && request.resource.data.part4.size() > 0;
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid)
        || (signedIn()
          && resource.data.keys().hasAll(['roomId'])
          && roomPresentersIncludeAuthUid(resource.data.roomId));
      allow update: if isAdmin()
        || (signedIn()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid);
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // ATTENDANCE  /attendance/{docId}
    // Participants can write their own records.
    // Signed-in event staff can also record attendance when recordedBy matches
    // their auth uid, which enables facilitator QR scanning.
    // ─────────────────────────────────────────────────────────────
    match /attendance/{docId} {
      allow create: if signedIn()
        && (
          request.resource.data.uid == request.auth.uid
          || request.resource.data.recordedBy == request.auth.uid
        );
      allow read:   if signedIn();
      allow update: if isAdmin()
        || (signedIn()
          && (
            request.resource.data.uid == request.auth.uid
            || request.resource.data.recordedBy == request.auth.uid
          ));
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // FOOD CLAIMS  /foodClaims/{docId}
    // Food booth operators create claims (claimedBy = their uid).
    // Any signed-in user can read: booths need to check duplicates;
    // participants read their own claims for "My Meals".
    // ─────────────────────────────────────────────────────────────
    match /foodClaims/{docId} {
      allow create: if signedIn()
        && request.resource.data.claimedBy == request.auth.uid;
      allow read:   if signedIn();
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // DIGITAL IDs  /digitalIds/{userId}
    // ─────────────────────────────────────────────────────────────
    match /digitalIds/{userId} {
      allow create: if isNonAdminOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isNonAdminOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // CERTIFICATES  /certificates/{certId}
    // ─────────────────────────────────────────────────────────────
    match /certificates/{certId} {
      allow create, update, delete: if isAdmin();
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────
    // PRESENTER MATERIALS  /presenterMaterials/{docId}
    // Presenters create/delete their own; admin reads/updates all.
    // Participants can read materials for rooms they have reserved.
    // ─────────────────────────────────────────────────────────────
    match /presenterMaterials/{docId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read:   if signedIn();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────
    // ROOM CHAT  /roomChat/{docId}
    // Participants create messages (questions); Admin and speakers read only.
    // ─────────────────────────────────────────────────────────────
    match /roomChat/{docId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // MAIL QUEUE  /mail/{docId}
    // ─────────────────────────────────────────────────────────────
    match /mail/{docId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ARTICLE CATEGORY EDITORS  /articleCategoryEditors/{uid}
    // Admins create/delete; the user may read their own doc (optional UI).
    // ─────────────────────────────────────────────────────────────
    match /articleCategoryEditors/{userId} {
      allow read: if signedIn() && (isAdmin() || isOwner(userId));
      allow create, update, delete: if isAdmin();
    }

    // ARTICLE CATEGORIES  /articleCategories/{docId}
    // Global labels for article posts; participants read for filters; admin + article authors manage.
    // ─────────────────────────────────────────────────────────────
    match /articleCategories/{categoryId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && canManageArticleCategories()
        && request.resource.data.keys().hasAll(['name', 'sortOrder', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.sortOrder is int
        && request.resource.data.createdAt is timestamp;
      allow update: if signedIn()
        && canManageArticleCategories()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.sortOrder is int;
      allow delete: if signedIn() && canManageArticleCategories();
    }

    // ARTICLES  /articles/{docId}
    // Public landing page reads this collection without sign-in.
    // Keep writes restricted to authenticated authors/admins.
    // Create: authorUid must match caller; core fields required (extras OK).
    // ─────────────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.keys().hasAll(['authorUid', 'title', 'description', 'createdAt', 'updatedAt']);
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.authorUid == resource.data.authorUid);
      allow delete: if isAdmin()
        || (request.auth != null && resource.data.authorUid == request.auth.uid);
    }
  }
}
