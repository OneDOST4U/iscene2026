rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────
    // PROFILE PICTURES  /profilePictures/{uid}/{fileName}
    // Images only, max 5 MB.
    // ─────────────────────────────────────────────────────────────
    match /profilePictures/{userId}/{fileName} {
      allow create, update: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow read:   if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // PROOF OF PAYMENT  /proofOfPayment/{uid}/{fileName}
    // Images or PDFs, max 100 MB.
    // ─────────────────────────────────────────────────────────────
    match /proofOfPayment/{userId}/{fileName} {
      allow create: if isOwner(userId)
        && request.resource.size < 100 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );

      allow read:   if isOwner(userId) || isAdmin();
      allow update: if false;
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // PRESENTER MATERIALS  /presenterMaterials/{uid}/{fileName}
    // Presenters upload their own files; admin can read all.
    // ─────────────────────────────────────────────────────────────
    match /presenterMaterials/{userId}/{fileName} {
      allow create: if isOwner(userId)
        && request.resource.size < 200 * 1024 * 1024;
      allow read:   if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      allow update: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // BOOTH IMAGES  /boothImages/{uid}/{fileName}
    // Food booth operators upload booth image and background.
    // ─────────────────────────────────────────────────────────────
    match /boothImages/{userId}/{fileName} {
      allow create, update: if (isOwner(userId) || isAdmin())
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if signedIn();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /boothBackgrounds/{userId}/{fileName} {
      allow create, update: if (isOwner(userId) || isAdmin())
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if signedIn();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // ROOM BACKGROUNDS  /roomBackgrounds/{path=**}
    // Admin and speakers upload room/session background images.
    // Paths: roomBackgrounds/{timestamp}_{name} (create) or roomBackgrounds/{roomId}/{timestamp}_{name} (edit)
    // Firestore rules control who can update the room doc; storage allows signed-in uploads.
    // ─────────────────────────────────────────────────────────────
    match /roomBackgrounds/{path=**} {
      allow create, update: if signedIn()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if signedIn();
      allow delete: if signedIn();
    }

    // ─────────────────────────────────────────────────────────────
    // CERTIFICATE FILES  /certificates/{uid}/{fileName}
    // Admin creates/manages; owner can download their own.
    // ─────────────────────────────────────────────────────────────
    match /certificates/{userId}/{fileName} {
      allow create, update, delete: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // ARTICLE ATTACHMENTS  /articleAttachments/{uid}/{fileName}
    // Same pattern as presenterMaterials: owner uploads; signed-in read.
    // No contentType guard (PDFs, Office, etc.); size cap only.
    // ─────────────────────────────────────────────────────────────
    match /articleAttachments/{userId}/{fileName} {
      allow create: if isOwner(userId)
        && request.resource.size < 50 * 1024 * 1024;
      allow read: if signedIn();
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ARTICLE HEADER IMAGES  /articleHeaders/{uid}/{fileName}
    // Optional banner shown on article cards / future public views.
    // ─────────────────────────────────────────────────────────────
    match /articleHeaders/{userId}/{fileName} {
      allow create: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if signedIn();
      allow delete: if isOwner(userId);
      allow update: if false;
    }
  }
}
